# Comma-separated list of phone numbers, Apple IDs, or group chat identifiers to monitor
# Use list_chats.py to find the exact chat_identifier values
# Examples:
#   Single:  CHAT_TARGET=+15551234567
#   Multiple: CHAT_TARGET=+15551234567,user@example.com,chat1a2b3c4d5e
CHAT_TARGET=+15551234567

# URL to POST when a new message arrives
WEBHOOK_URL=http://localhost:9000/hook

HOST=127.0.0.1
PORT=5000

# Seconds between chat.db polls (default: 2)
POLL_INTERVAL=2
