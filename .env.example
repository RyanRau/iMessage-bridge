# Chat targets and webhook URLs are configured in chats.json (see chats.json.example)

HOST=127.0.0.1
PORT=5000

# Seconds between chat.db polls (default: 2)
POLL_INTERVAL=2

# Your phone number or Apple ID — used to detect when you are @mentioned in a group chat.
# Leave unset (or empty) to disable mention detection (mentioned will always be false).
# HOST_HANDLE=+15551234567
